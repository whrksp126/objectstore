# ───── MinIO root credentials ─────
# 길이 제약: USER ≥ 3자, PASSWORD ≥ 8자.
# root 계정은 Console 관리용. 애플리케이션이 쓸 access key는 Console에서 별도 발급해서 쓸 것.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme_at_least_8_chars

# ───── 호스트 포트 (로컬 전용; prod에선 ports!reset 으로 무력화됨) ─────
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# ───── MinIO가 내부적으로 인지할 외부 URL ─────
# 로컬: 그대로 두면 됨.
# 홈서버 .env.dev: 두 값을 https://objectstore.ghmate.com / https://objectstore-console.ghmate.com 로 바꿀 것.
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
